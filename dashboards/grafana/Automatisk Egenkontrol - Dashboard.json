          "rawSql": "SELECT \r\n  CONCAT(floor, ' - ', room, ' - ', appliance) AS \"Værdi\",\r\n  AVG(temperature) AS value \r\nFROM \r\n  \"mtaarhus-kommune\".\"etrefrigerator-sensor\"\r\nWHERE \r\n  name IN ($sensorID)\r\n  AND DATE_PART('week', time_index) = CAST(SPLIT_PART('$Uge', '-', 2) AS INTEGER) -- Extract the week number\r\n  AND DATE_PART('year', time_index) = CAST(SPLIT_PART('$Uge', '-', 1) AS INTEGER) -- Filter by year\r\n  AND appliance IS NOT NULL -- Exclude appliances that are NULL\r\n  AND LOWER(appliance) LIKE '%fry%' -- Filter for refrigerators\r\n  AND time_index BETWEEN $__timeFrom()::timestamp AND $__timeTo()::timestamp\r\nGROUP BY \r\n  floor, room, appliance -- Group by all columns used in CONCAT\r\nORDER BY \r\n  floor, room, appliance;\r\n",
