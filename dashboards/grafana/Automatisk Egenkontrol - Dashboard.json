          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  CONCAT(floor, ' - ', room, ' - ', appliance) AS metric,\r\n  AVG(temperature) AS value\r\nFROM \"mtaarhus-kommune\".\"etrefrigerator-sensor\"\r\nWHERE\r\n  department IN ('$department') \r\n  AND name IN ($sensorID)\r\n  AND DATE_PART('week', time_index) = CAST(SPLIT_PART('$Uge', '-', 2) AS INTEGER) -- Extract the week number\r\n  AND DATE_PART('year', time_index) = CAST(SPLIT_PART('$Uge', '-', 1) AS INTEGER) -- Filter by year\r\n  AND appliance IS NOT NULL -- Exclude appliances that are NULL\r\n  AND (\r\n    LOWER(appliance) LIKE '%køl%' \r\n    OR LOWER(appliance) LIKE '%frugt%' \r\n    OR LOWER(appliance) LIKE '%grønt%'\r\n  ) -- Include \"køl\", \"frugt\", and \"grønt\"\r\nGROUP BY metric\r\nORDER BY 1, 2;\r\n",
          "refId": "A",
