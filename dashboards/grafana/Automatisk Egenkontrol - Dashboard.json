          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_per_entity AS (\r\n  SELECT DISTINCT ON (entity_id)\r\n    entity_id,\r\n    floor, room, appliance,\r\n    temperature,\r\n    time_index\r\n  FROM \"mtaarhus-kommune\".\"etrefrigerator-sensor\"\r\n  WHERE\r\n    $__timeFilter(time_index)\r\n    AND department IN ('$department')\r\n    AND name IN ($sensorID)\r\n    AND (\r\n      lower(appliance) LIKE '%køl%' OR lower(appliance) LIKE '%koel%' OR lower(appliance) LIKE '%kol%'\r\n      OR lower(appliance) LIKE '%frugt%'\r\n      OR lower(appliance) LIKE '%grønt%' OR lower(appliance) LIKE '%groent%'\r\n    )\r\n  ORDER BY\r\n    entity_id,\r\n    time_index DESC                 -- newest row per entity_id\r\n),\r\nlatest_entity_per_location AS (\r\n  SELECT DISTINCT ON (floor, room, appliance)\r\n    entity_id,\r\n    floor, room, appliance,\r\n    temperature,\r\n    time_index\r\n  FROM latest_per_entity\r\n  ORDER BY\r\n    floor, room, appliance,\r\n    time_index DESC                 -- newest entity (by last seen time) for that combo\r\n)\r\nSELECT\r\n  CONCAT(floor, ' - ', room, ' - ', appliance) AS \"sammenkædning\",\r\n  ROUND(temperature::numeric, 1)               AS value\r\nFROM latest_entity_per_location\r\nORDER BY \"sammenkædning\";\r\n",
          "refId": "A",
          "sql": {
            "columns": [
